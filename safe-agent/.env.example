# ============================================================
# Safe Automation Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# Shared secret token for cloud ↔ laptop authentication.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SAFE_AGENT_TOKEN=S885MgpDQS4tMTXomH2l6AUutPWBKc3KoNgwZcKw314

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=8607994806:AAEWMLpLBWPVh3Lrdk0eU1DYmk4FZvEGDSY

# Comma-separated Telegram chat IDs allowed to use the bot.
# Send /start to your bot and check logs to find your chat ID.
ALLOWED_CHAT_IDS=6729388892

# Cloud agent bind address (default: 0.0.0.0:8000)
CLOUD_HOST=0.0.0.0
CLOUD_PORT=8000

# URL the laptop uses to reach the cloud agent.
# In Codespaces this is the forwarded port URL.
# Example: https://your-codespace-8000.app.github.dev
CLOUD_AGENT_URL=http://localhost:8000

# Seconds between laptop polls (default: 3)
POLL_INTERVAL=3
